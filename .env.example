# Comma-separated browser origins allowed to call the API cross-origin.
# Leave empty for same-origin Vercel deployment.
CORS_ORIGINS=

# MongoDB connection URL used by the training pipeline.
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/customer_db?retryWrites=true&w=majority&tls=true

# AWS credentials used to read the trained model from S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional. Enables the protected /train route only when set in production.
TRAINING_API_KEY=
