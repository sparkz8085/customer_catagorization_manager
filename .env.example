# Comma-separated browser origins allowed to call the API cross-origin.
# Leave empty for same-origin Vercel deployment.
CORS_ORIGINS=

# MongoDB connection URL used by the training pipeline.
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/customer_db?retryWrites=true&w=majority&tls=true

# Optional. Enables the protected /train route only when set in production.
TRAINING_API_KEY=

# Set to 1 to trust local model deserialization (enforces safe classes only).
MODEL_TRUSTED=1

# JWT/HMAC Session signing secret. Provide a long random string.
SESSION_SECRET_KEY=customer_categorizer_default_session_secret_key_change_in_prod

# Google OAuth2 credentials (Optional - enables real login redirection)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth2 credentials (Optional - enables real login redirection)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
